# settings.toml.example
# Canonical default settings for the personal AI Constitution system.
#
# Location: ~/.config/aiConstitution/settings.toml
#   (Windows: %APPDATA%\aiConstitution\settings.toml)
#
# Generated by `ai settings reset --accept-defaults`. Hand-editing is
# allowed; use `ai settings edit` for a validated round-trip. Invalid
# values are rejected with the specific failing constraint.
#
# Precedence (highest wins):
#   1. Environment variable (e.g. AICONST_REVIEW_CADENCE_DAYS=14)
#   2. This file
#   3. Defaults compiled into bin/ai
#
# Schema: governance/schemas/settings.schema.json (versioned with schemaVersion below)

schemaVersion = "0.4"


# ─── upstream contribution ────────────────────────────────────────────────────
[upstream]

# Share AI-authored hooks back to convergent-systems-co/ai as issues.
#
# When the AI creates a hook in response to a finding (spec §9), it offers to
# file the hook as an upstream `hook` issue. Setting this to `true` means:
# file automatically without per-event prompt (pre-submission review window
# still shows unless skipReviewWindow=true below). Setting to `false` means:
# ask each time.
shareNewHooks = true

# Share AI-authored skills back to the public repo. Conservative default:
# false. Skills can carry project-specific context that users may not want
# public.
shareNewSkills = false

# Auto-file major findings as `finding` issues upstream. A "major finding"
# is a violation tagged severity=major, a pattern observed >=3 times across
# sessions, or anything tagged with `ai issue file --major`.
shareMajorFindings = false

# Skip the per-event review window before an upstream issue is filed.
# Independent of shareNewHooks/shareMajorFindings — an extra opt-in layer
# for users who want fully automated submission.
skipReviewWindow = false

# Where upstream issues are filed.
upstreamRepo = "convergent-systems-co/ai"


# ─── memory review cadence ────────────────────────────────────────────────────
[review]

# How often `ai status` and `ai` startup nag for a memory review.
# Per spec §6.5. 0 disables the nag entirely; the codification loop still
# works on demand.
cadenceDays = 30

# What `ai review --check` reports on at this cadence.
includeMemory = true
includeAuditOverrides = true
includeAuditViolations = true


# ─── update reconciliation ────────────────────────────────────────────────────
[update]

# On first `ai` invocation after a binary version bump (detected via
# governance/last-seen-version), enter the migration prompt. Per spec §8.
autoMigratePrompt = true

# Skip per-item prompts during migration; apply all changes. Strongly
# discouraged — the migration prompt is designed to be walked through.
autoMigrateApprove = false


# ─── telemetry (opt-in only) ──────────────────────────────────────────────────
[telemetry]

# Anonymous install ping (country code, OS, install method). Opt-in.
# No other telemetry exists. Adding any other key to this section is a defect.
installPing = false


# ─── pre-commit secret scanning ───────────────────────────────────────────────
[secret_scanning]

# Where to install the pre-commit secret hook.
#   "ai-only"      — protect only the ~/.ai/ repo itself.
#   "current-repo" — install per-request via `ai hooks install secret-precommit --repo=<path>`.
#   "all-repos"    — wires into bin/clone so every fresh clone gets the hook.
installScope = "all-repos"

# Allow `git commit --no-verify` to bypass the pre-commit scan.
# `false` (default) installs a ~/.ai/bin/git wrapper that strips --no-verify
# before exec'ing the real git. Per spec §10.3.
allowNoVerifyBypass = false

# Whether to also wire a server-side scanner in CI as defense-in-depth.
# Per spec §10.3 the canonical recommendation is "none" (the local pre-commit
# is authoritative); set to "gitleaks" for users who want the CI net.
# Trufflehog is deliberately not an option — see spec §10.4.
ciScanner = "none"  # "none" | "gitleaks"


# ─── command wrapper facade (per spec §10.5) ─────────────────────────────────
[command_wrappers]

# Master switch. False removes the wrappers from ~/.ai/bin/; the underlying
# tools are reached via standard PATH.
enabled = true

# Allow `ai settings set command_wrappers.commands.<cmd>=disabled` at runtime.
# False locks wrappers on once enabled; only `ai update --migrate` can disable.
allowDisable = true

[command_wrappers.commands]
# Per-command toggles. "enabled" wires the wrapper; "disabled" removes it.
git = "enabled"
gh = "enabled"
terraform = "disabled"   # opt-in; many environments don't have terraform
kubectl = "disabled"     # opt-in


# ─── atoms registry (per spec §7.9 + §7.10 + §7.11) ──────────────────────────
[atoms]

# Where to resolve atoms. Override for private mirrors that serve the same API.
personaRegistry  = "https://persona-atoms.com"   # both /agentic/ and /reviewer/ resolve under this
profileRegistry  = "https://profile-atoms.com"
skillRegistry    = "https://skill-atoms.com"     # NEW v0.6
brandRegistry    = "https://brand-atoms.com"
actionRegistry   = "https://action-atoms.com"    # NEW v0.10 — atomic CI actions (composite/JS/Docker)
workflowRegistry = "https://workflow-atoms.com"  # v0.9; refocused v0.10 — reusable workflows only
pipelineRegistry = "https://pipeline-atoms.com"  # NEW v0.10 — pipelines (workflows of workflows)

# Default install behavior for the GitHub Actions trinity at setup
# time. Q36d in the wizard sets this. Per-layer details below in
# [action] / [workflow] / [pipeline].
install = "skip"   # "pick-per-layer" | "recommended" | "skip"

# Verify SHA-256 content hash on every cache load. action / workflow /
# pipeline atoms are verified by GitHub Actions itself at uses-time
# (the `uses:` line pins a SHA or tag); the binary's hash check
# applies only when an atom is read for the catalog browser / install
# command.
verifyContentHash = true


# ─── per-kind cache TTLs (NEW v0.7, per spec §7.9.5) ─────────────────────────
# Cached CONTENT for a pinned version is never invalidated (atoms are immutable
# at version). These TTLs govern (a) how often the binary checks the registry
# for newer versions, and (b) when unused/unreferenced versions get GC'd.

[atoms.cache.agentic]
freshnessCheckDays = 7
gcUnusedDays = 90

[atoms.cache.reviewer]
freshnessCheckDays = 7
gcUnusedDays = 90

[atoms.cache.profile]
freshnessCheckDays = 14
gcUnusedDays = 90

[atoms.cache.skill]
freshnessCheckDays = 7
gcUnusedDays = 90

[atoms.cache.brand]
freshnessCheckDays = 30
gcUnusedDays = 180

# Action / workflow / pipeline atoms (v0.10 — was just `workflow` in
# v0.9). Cache governs catalog browsing and the `ai {action,workflow,
# pipeline} install` stub generator. The actual content is fetched
# by GitHub Actions at uses-time from the upstream repo, so these
# TTLs are operationally about local catalog freshness, not
# deploy-time correctness.
[atoms.cache.action]
freshnessCheckDays = 7
gcUnusedDays = 90

[atoms.cache.workflow]
freshnessCheckDays = 7
gcUnusedDays = 90

[atoms.cache.pipeline]
freshnessCheckDays = 7
gcUnusedDays = 90

[atoms.cache]
# Never GC a version that's actively referenced by any profile, skill manifest,
# panel composition, or active mode.json — regardless of gcUnusedDays age.
gcRespectReferences = true


# ─── Claude plugins (per spec §11, expanded in v0.7) ─────────────────────────
[plugins]

# Plugins offered during wizard Q36b/c. Listed plugins are eligible for
# `ai plugins enable`. The five candidates spec'd in §11.1 plus `superpowers`.

# ─── workflow atoms (v0.9, per spec §7.11) ───────────────────────────────────
# Note: this block lives BELOW [plugins] and ABOVE [drafts] in the
# canonical settings.toml shape. Splitting the comment up here to keep
# the auto-generated examples readable.
enabled = []
# Example after setup:
# enabled = ["superpowers"]

# Fall back to planner personas when plugins aren't installed (F12 elaboration).
# When true, declining a plugin during setup activates the matching agentic
# persona that provides degraded-but-functional guidance for the same workflow.
plannerPersonaFallback = true


# ─── action / workflow / pipeline atoms (v0.10, per spec §7.11) ──────────────
# Three sibling sections — same shape per registry. Q36e/f/g populate
# them. Mandatory `uses:` pinning is enforced under [atoms.gh] below.

[action]
# Atoms installed from action-atoms.com (`steps[].uses:` consumers).
enabled = []
# Example after wizard:
# enabled = [
#   "secret-scan-patterns",
#   "setup-cs-tofu",
#   "cs-page-deployment",
# ]

[workflow]
# `ai workflow install` writes .github/workflows/<name>.yml that
# `uses:` the named atom. The `enabled` list is what the wizard
# offered (Q36f) and what `ai update --migrate` will re-evaluate on
# each upgrade.
enabled = []
# Example after wizard:
# enabled = ["astro-build", "ci-go-workspace"]

[pipeline]
# Atoms installed from pipeline-atoms.com (top-level workflow
# composers). Q36g populates this.
enabled = []
# Example: enabled = ["release-train"]

# Require pinning every `uses: convergent-systems-co/<registry>/...`
# to a specific version (tag or SHA), never `@main`. `ai doctor`
# surfaces violations. Off-the-record fix is editing the file by hand,
# but per spec §7.11.3 mandatory pinning is the immutability invariant.
[atoms.gh]
requirePinning = true


[drafts]

publishNudgeAfterDays = 30
suppressNudge = false


# ─── modes / personas / focus ─────────────────────────────────────────────────
[focus]

# Mode loaded on session start. Format: "<name>" resolves via the priority
# order (drafts → atom registries). To pin a specific atom version, use
# "<name>@<version>". "none" means the four-file constitution only.
#
# Examples:
#   defaultMode = "polliard-coder@0.5.0"  # pinned to a specific atom version
#   defaultMode = "polliard-coder"         # latest available; not recommended for stability
#   defaultMode = "none"                   # no persona/profile by default
defaultMode = "none"

# When resolving an unversioned name, prefer the most recent stable version
# over any newer pre-release. Recommended.
preferStableVersions = true


# ─── wizard versioning ────────────────────────────────────────────────────────
[wizard]

# Version of governance/wizard/questions.yaml the user's answers.yaml was
# generated against. `ai update --migrate` reads this to detect new questions
# added since the last setup.
lastSeenWizardVersion = "0.10"


# ─── sync ─────────────────────────────────────────────────────────────────────
[sync]

# Include this settings file in `ai sync push`. Per spec §12.4 the schema
# explicitly excludes secrets; nothing here is sensitive by design.
# Default true; set false for per-machine settings.
includeSettingsFile = true


# ─── advanced path overrides ──────────────────────────────────────────────────
[paths]

# Override locations. Empty string = use default.
aiRoot = ""           # default: $HOME/.ai
configDir = ""        # default: per os.UserConfigDir() + /aiConstitution


# End of settings.
#
# What's NEVER in this file:
#   - Secrets (any kind)
#   - PII other than the principal name (which is in Constitution.md, not here)
#   - Tokens, URLs with credentials, paths to vaults
#
# `ai sync push` scans this file's body against hooks/patterns.json before
# inclusion. Any match aborts the push.
