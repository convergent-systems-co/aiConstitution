---
import Base from '../layouts/Base.astro';
---
<Base title="Page not found">
  <section class="cs-prose" style="text-align: center; padding-block: var(--space-24);">
    <p class="cs-section-label">404</p>
    <h1>Page not found</h1>
    <p>The page you requested does not exist or has moved.</p>
    <p style="margin-block-start: var(--space-8);">
      <a class="cs-action" href="/">Go home</a>
    </p>
  </section>
</Base>
